# iikoweb доступ
IIKO_WEB_URL=https://iskendi.iikoweb.ru
IIKO_WEB_LOGIN=Ataev
IIKO_WEB_PASSWORD=your_password_here
IIKO_STORE_ID=161059

DATABASE_URL=sqlite:///./iskendi.db

# Часовой пояс ресторана: задаёт границы «сегодня/неделя/месяц» и расписание синков
# (не зависит от TZ контейнера). По умолчанию Europe/Moscow.
TIMEZONE=Europe/Moscow

# TTL in-memory кэша живых чтений из iikoweb (get-data/OLAP), сек. 0 — кэш выключен.
CACHE_TTL_SECONDS=60

# Частый синк текущего дня в БД, сек (дашборд отдаёт «сегодня» из БД). 0 — выключить.
TODAY_SYNC_SECONDS=180

# Авторизация дашборда (обязательно задать пароль — иначе вход невозможен).
# Один общий логин/пароль на весь дашборд; сессия — JWT в localStorage.
AUTH_USERNAME=admin
AUTH_PASSWORD=change_me
# Секрет подписи JWT. Если пуст — выводится из пароля. Задайте свой для ротации сессий.
JWT_SECRET=
# Срок жизни сессии, часов.
JWT_TTL_HOURS=12

# Домен для продакшен-запуска через Caddy (docker-compose.prod.yml).
# Нужна A-запись DNS на IP сервера + открытые порты 80/443 → авто-HTTPS.
# Для dev (docker-compose.yml) не используется.
DOMAIN=analytics.example.com
